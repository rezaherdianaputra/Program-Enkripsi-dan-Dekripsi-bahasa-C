#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <stdint.h>
#include <time.h> 

#define BLOCK_SIZE 8 

void fungsi_substitusi(unsigned char* block) {
    for(int i = 0; i < BLOCK_SIZE; i++) { block[i] = block[i] + 3; }
}
void reverse_substitusi(unsigned char* block) {
    for(int i = 0; i < BLOCK_SIZE; i++) { block[i] = block[i] - 3; }
}
void fungsi_xor(unsigned char* block, unsigned char* key) {
    for(int i = 0; i < BLOCK_SIZE; i++) { block[i] = block[i] ^ key[i]; }
}

void encrypt_block(unsigned char* block, unsigned char* key) {
    fungsi_substitusi(block); 
    fungsi_xor(block, key);   
}
void decrypt_block(unsigned char* block, unsigned char* key) {
    fungsi_xor(block, key);       
    reverse_substitusi(block);    
}


void encrypt_cbc(unsigned char* plaintext, int len, unsigned char* key, unsigned char* iv, unsigned char* ciphertext) {
    unsigned char prev_cipher[BLOCK_SIZE];
    memcpy(prev_cipher, iv, BLOCK_SIZE); 
    for (int i = 0; i < len; i += BLOCK_SIZE) {
        for (int j = 0; j < BLOCK_SIZE; j++) ciphertext[i + j] = plaintext[i + j] ^ prev_cipher[j];
        encrypt_block(&ciphertext[i], key); 
        memcpy(prev_cipher, &ciphertext[i], BLOCK_SIZE); 
    }
}
void decrypt_cbc(unsigned char* ciphertext, int len, unsigned char* key, unsigned char* iv, unsigned char* plaintext) {
    unsigned char prev_cipher[BLOCK_SIZE];
    unsigned char current_cipher[BLOCK_SIZE];
    memcpy(prev_cipher, iv, BLOCK_SIZE); 
    for (int i = 0; i < len; i += BLOCK_SIZE) {
        memcpy(current_cipher, &ciphertext[i], BLOCK_SIZE); 
        memcpy(&plaintext[i], &ciphertext[i], BLOCK_SIZE);
        decrypt_block(&plaintext[i], key); 
        for (int j = 0; j < BLOCK_SIZE; j++) plaintext[i + j] ^= prev_cipher[j];
        memcpy(prev_cipher, current_cipher, BLOCK_SIZE); 
    }
}

static const char b64_table[] = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";

void base64_encode(const unsigned char *src, size_t len, char *out) {
    size_t i = 0, j = 0; 
    while (i < len) {
        int step = 1;
        uint32_t octet_a = src[i++];
        uint32_t octet_b = 0, octet_c = 0;
        if (i < len) { octet_b = src[i++]; step++; }
        if (i < len) { octet_c = src[i++]; step++; }
        uint32_t triple = (octet_a << 16) + (octet_b << 8) + octet_c;
        out[j++] = b64_table[(triple >> 18) & 0x3F];
        out[j++] = b64_table[(triple >> 12) & 0x3F];
        out[j++] = (step > 1) ? b64_table[(triple >> 6) & 0x3F] : '=';
        out[j++] = (step > 2) ? b64_table[(triple & 0x3F)] : '=';
    }
    out[j] = '\0'; 
}

int b64_char_to_val(char c) {
    if (c >= 'A' && c <= 'Z') return c - 'A';
    if (c >= 'a' && c <= 'z') return c - 'a' + 26;
    if (c >= '0' && c <= '9') return c - '0' + 52;
    if (c == '+') return 62;
    if (c == '/') return 63;
    return -1; 
}

size_t base64_decode(const char *in, unsigned char *out) {
    size_t len = strlen(in);
    if (len == 0 || len % 4 != 0) return 0; 
    size_t out_len = len / 4 * 3;
    if (in[len-1] == '=') out_len--;
    if (in[len-2] == '=') out_len--;
    size_t i, j = 0;
    for (i = 0; i < len; i += 4) {
        int v1 = b64_char_to_val(in[i]), v2 = b64_char_to_val(in[i+1]);
        int v3 = b64_char_to_val(in[i+2]), v4 = b64_char_to_val(in[i+3]);
        uint32_t triple = (v1 << 18) | (v2 << 12) | ((v3 >= 0 ? v3 : 0) << 6) | (v4 >= 0 ? v4 : 0);
        out[j++] = (triple >> 16) & 0xFF;
        if (v3 >= 0) out[j++] = (triple >> 8) & 0xFF;
        if (v4 >= 0) out[j++] = triple & 0xFF;
    }
    return out_len;
}

void hapus_newline(char* str) {
    str[strcspn(str, "\r\n")] = 0; 
}

void set_8_byte_input(const char* input, unsigned char* dest) {
    memset(dest, '0', BLOCK_SIZE); 
    int len = strlen(input);
    if (len > BLOCK_SIZE) len = BLOCK_SIZE;
    memcpy(dest, input, len);
}

void generate_random_iv(unsigned char* iv) {
    for(int i = 0; i < BLOCK_SIZE; i++) {
        iv[i] = rand() % 256; 
    }
}

int main() {
    srand(time(NULL)); 

    char pilihan[10];
    char input_buffer[1024];
    char key_input[256];
    
    unsigned char key[BLOCK_SIZE];

    while (1) {
        printf("\n====================================\n");
        printf("  APLIKASI ENKRIPSI CBC\n");
        printf("====================================\n");
        printf("1. Enkripsi Pesan\n");
        printf("2. Dekripsi Teks\n");
        printf("3. Keluar\n");
        printf("Pilih menu (1/2/3): ");
        
        fgets(pilihan, sizeof(pilihan), stdin);
        hapus_newline(pilihan);

        if (strcmp(pilihan, "3") == 0) {
            printf("Program selesai. Terima kasih!\n");
            break;
        }

        if (strcmp(pilihan, "1") != 0 && strcmp(pilihan, "2") != 0) {
            printf("Pilihan tidak valid!\n");
            continue;
        }

        printf("\n[+] Masukkan Key (Maks 8 karakter): ");
        fgets(key_input, sizeof(key_input), stdin);
        hapus_newline(key_input);
        set_8_byte_input(key_input, key);

        if (strcmp(pilihan, "1") == 0) {
            printf("Masukkan pesan yang mau dienkripsi:\n> ");
            fgets(input_buffer, sizeof(input_buffer), stdin);
            hapus_newline(input_buffer);

            int len = strlen(input_buffer);
            int padded_len = (len % BLOCK_SIZE == 0) ? len : len + (BLOCK_SIZE - (len % BLOCK_SIZE));
            
            unsigned char plaintext[padded_len];
            memset(plaintext, 0, padded_len); 
            memcpy(plaintext, input_buffer, len);

            unsigned char ciphertext[padded_len];
            unsigned char iv[BLOCK_SIZE];

            generate_random_iv(iv);

            encrypt_cbc(plaintext, padded_len, key, iv, ciphertext);

            int combined_len = BLOCK_SIZE + padded_len;
            unsigned char combined_data[combined_len];
            memcpy(combined_data, iv, BLOCK_SIZE); 
            memcpy(combined_data + BLOCK_SIZE, ciphertext, padded_len); 

            char base64_output[(combined_len * 4 / 3) + 4]; 
            base64_encode(combined_data, combined_len, base64_output);

            printf("\n--- HASIL ENKRIPSI ---\n");
            printf("Output: %s\n", base64_output);
            printf("----------------------------------\n");

        } else if (strcmp(pilihan, "2") == 0) {
            printf("[?] Masukkan teks output untuk didekripsi:\n> ");
            fgets(input_buffer, sizeof(input_buffer), stdin);
            hapus_newline(input_buffer);

            unsigned char combined_mentah[1024];
            size_t decoded_len = base64_decode(input_buffer, combined_mentah);

            if (decoded_len < BLOCK_SIZE || decoded_len % BLOCK_SIZE != 0) {
                printf("\n[ERROR] Teks tidak valid!\n");
                continue;
            }

            unsigned char iv_extracted[BLOCK_SIZE];
            memcpy(iv_extracted, combined_mentah, BLOCK_SIZE); 

            int ciphertext_len = decoded_len - BLOCK_SIZE;
            unsigned char ciphertext_extracted[ciphertext_len];
            memcpy(ciphertext_extracted, combined_mentah + BLOCK_SIZE, ciphertext_len); 

            unsigned char decrypted[ciphertext_len + 1]; 
            memset(decrypted, 0, ciphertext_len + 1);

            decrypt_cbc(ciphertext_extracted, ciphertext_len, key, iv_extracted, decrypted);

            printf("\n--- HASIL DEKRIPSI ---\n");
            printf("Pesan Asli: %s\n", decrypted);
            printf("----------------------\n");
        }
    }
    return 0;
}
